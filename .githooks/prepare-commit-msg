#!/bin/sh
# Strip the "Co-authored-by: Cursor <cursoragent@cursor.com>" trailer
# that Cursor IDE auto-injects when committing from the agent shell.
# Runs locally on every commit; safe no-op if the trailer is absent.

MSG_FILE="$1"
[ -z "$MSG_FILE" ] && exit 0
[ ! -f "$MSG_FILE" ] && exit 0

# Remove the cursor co-author line(s)
grep -v '^Co-authored-by: Cursor <cursoragent@cursor\.com>$' "$MSG_FILE" > "$MSG_FILE.tmp"

# Collapse trailing blank lines that the trailer may have left behind
awk 'NF{p=1} p' "$MSG_FILE.tmp" | awk 'BEGIN{n=0} {a[NR]=$0} END{ for(i=NR;i>=1;i--){ if(a[i]!="") {last=i; break} } for(i=1;i<=last;i++) print a[i] }' > "$MSG_FILE"

rm -f "$MSG_FILE.tmp"
exit 0

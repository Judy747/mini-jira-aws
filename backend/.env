PORT=4000
NODE_ENV=development

AWS_REGION=us-east-1

# Cognito User Pool + app client (USER_PASSWORD_AUTH enabled on client)
COGNITO_USER_POOL_ID=us-east-1_WHMObRkog
COGNITO_CLIENT_ID=3dolvfcfhbg6qnkerfff8on7fh


# Optional dev helper: auto-confirm signups (requires cognito-idp:AdminConfirmSignUp)
# COGNITO_AUTO_CONFIRM=true

# DynamoDB table names (create tables + GSIs to match README)
DYNAMODB_USERS_TABLE=mini-jira-users
DYNAMODB_TEAMS_TABLE=mini-jira-teams
DYNAMODB_PROJECTS_TABLE=mini-jira-projects
DYNAMODB_TASKS_TABLE=mini-jira-tasks
DYNAMODB_COMMENTS_TABLE=mini-jira-comments

# S3 bucket for presigned PUT uploads
S3_BUCKET_NAME=mini-jira-attachments-youraccount
# Optional: CloudFront or public URL base for objects (otherwise regional S3 URL is used)
# S3_PUBLIC_BASE_URL=https://d111111abcdef8.cloudfront.net

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

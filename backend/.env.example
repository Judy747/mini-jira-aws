PORT=4000
NODE_ENV=development
AWS_REGION=us-east-1
CORS_ORIGIN=http://localhost:5173

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

DYNAMODB_USERS_TABLE=mini-jira-users
DYNAMODB_TEAMS_TABLE=mini-jira-teams
DYNAMODB_PROJECTS_TABLE=mini-jira-projects
DYNAMODB_TASKS_TABLE=mini-jira-tasks
DYNAMODB_COMMENTS_TABLE=mini-jira-comments
DYNAMODB_STATUS_AUDIT_TABLE=mini-jira-status-audit
DYNAMODB_ACTIVITY_LOG_TABLE=mini-jira-activity-log

# Originals bucket (versioning ON in AWS)
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=

# Thumbnails bucket (Lambda target)
S3_RESIZED_BUCKET_NAME=
S3_RESIZED_PUBLIC_BASE_URL=

# Task assignment notifications (SNS → SQS → worker Lambda)
# Also add to SSM: /mini-jira/prod/SNS_TASK_ASSIGNMENT_TOPIC_ARN (same value)
SNS_TASK_ASSIGNMENT_TOPIC_ARN=arn:aws:sns:us-east-1:744683930574:mini-jira-task-assignments

# Assignment worker Lambda email (Gmail + App Password — NOT student/university SMTP on smtp.gmail.com)
# Push to Lambda: node scripts/update-assignment-worker-env.js
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your-gmail-app-password

# Daily digest Lambda (deploy via infra/digest-lambda.yaml — not used by Express API)
# SNS_DIGEST_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mini-jira-prod-digest
# DYNAMODB_TASKS_TABLE=mini-jira-tasks
# DYNAMODB_USERS_TABLE=mini-jira-users
# DIGEST_TIMEZONE=Africa/Cairo

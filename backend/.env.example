PORT=4000
NODE_ENV=development

AWS_REGION=us-east-1

COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED if your Cognito app client was created WITH a client secret.
# Error: "Client ... is configured with secret but SECRET_HASH was not received"
# → Paste the client secret here, OR create a new app client without a secret in Cognito.
# COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# COGNITO_AUTO_CONFIRM=true

DYNAMODB_USERS_TABLE=mini-jira-users
DYNAMODB_TEAMS_TABLE=mini-jira-teams
DYNAMODB_PROJECTS_TABLE=mini-jira-projects
DYNAMODB_TASKS_TABLE=mini-jira-tasks
DYNAMODB_COMMENTS_TABLE=mini-jira-comments

S3_BUCKET_NAME=mini-jira-attachments-youraccount
# S3_PUBLIC_BASE_URL=https://d111111abcdef8.cloudfront.net

CORS_ORIGIN=http://localhost:5173
